<?xml version="1.0" encoding="utf-8"?>
<!-- ViewType: TYPE_HEADER — hero image + CTA copy -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="16dp">

    <ImageView
        android:id="@+id/paywall_hero_image"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/paywall_hero_content_description"
        android:adjustViewBounds="true" />

    <TextView
        android:id="@+id/paywall_cta_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textStyle="bold"
        android:textColor="@color/paywall_on_background"
        android:gravity="center_horizontal" />

    <TextView
        android:id="@+id/paywall_cta_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="@color/paywall_on_surface_variant"
        android:gravity="center_horizontal" />

</LinearLayout>
