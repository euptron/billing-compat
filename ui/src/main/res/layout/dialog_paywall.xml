<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/paywall_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paywall_background"
    android:fitsSystemWindows="false">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/paywall_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:nestedScrollingEnabled="false"
        android:overScrollMode="never"
        android:paddingTop="56dp"
        android:paddingBottom="24dp" />

    <LinearLayout
        android:id="@+id/paywall_top_bar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/paywall_scrim"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/paywall_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/paywall_on_background"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/paywall_cancel_button"
            style="?attr/materialIconButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Paywall.Close.Button"
            app:icon="@drawable/ic_paywall_close" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>